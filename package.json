{
  "name": "linkedin-outreach-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev -- --hostname 0.0.0.0 --port 3000",
    "build:web": "npm --prefix apps/web run build -- --no-lint",
    "start:web": "npm --prefix apps/web run start -- --hostname 0.0.0.0 --port 3000",
    "lint:web": "npm --prefix apps/web run lint",
    "runtime:dev": "WEB_RUNTIME=dev ./run_all.sh --web --agent --sender --message-only --followup",
    "runtime:prod": "WEB_RUNTIME=prod ./run_all.sh --web --agent --sender --message-only --followup"
  }
}
